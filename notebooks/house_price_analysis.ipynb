    {
      "cell_type": "code",
      "source": [
        "# Feature Scaling"
      ],
      "metadata": {
        "id": "fUwHlJVJX44i"
      },
      "execution_count": 28,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# CELL 18 — Feature Scaling\n",
        "\n",
        "# Problem: Features have very different value ranges.\n",
        "#   median_income → 0 to 15\n",
        "#   total_rooms   → 0 to 39,000\n",
        "#\n",
        "# This causes models to treat larger numbers as more important\n",
        "# even when they are not.\n",
        "#\n",
        "# Solution: StandardScaler transforms every feature to:\n",
        "#   Mean = 0 and Standard Deviation = 1\n",
        "#\n",
        "# Note: We do NOT scale median_house_value (our target)\n",
        "# because we want our predictions in real dollar amounts.\n",
        "\n",
        "\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "\n",
        "# These are the features we want to scale\n",
        "features_to_scale = [\n",
        "    'housing_median_age',\n",
        "    'median_income',\n",
        "    'rooms_per_household',\n",
        "    'bedrooms_per_room',\n",
        "    'population_per_household',\n",
        "    'log_total_rooms',\n",
        "    'log_total_bedrooms',\n",
        "    'log_population',\n",
        "    'log_households'\n",
        "]\n",
        "\n",
        "# Create scaler\n",
        "scaler = StandardScaler()\n",
        "\n",
        "# Applying scaling — fit_transform learns the mean and std\n",
        "# from our data then scales it in one step\n",
        "df[features_to_scale] = scaler.fit_transform(df[features_to_scale])\n",
        "\n",
        "print(\"\\nSample of scaled features (first 3 rows):\")\n",
        "print(df[features_to_scale].head(3).round(3))\n",
        "\n",
        "print(\"\\nMean of scaled features (should all be ~0):\")\n",
        "print(df[features_to_scale].mean().round(3))\n",
        "\n",
        "print(\"\\nStd of scaled features (should all be ~1):\")\n",
        "print(df[features_to_scale].std().round(3))"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
