    {
      "cell_type": "code",
      "source": [
        "# CELL 17 — Encoding ocean_proximity (One-Hot Encoding)\n",
        "\n",
        "# Models can only work with numbers — not text.\n",
        "# One-hot encoding converts ocean_proximity into 0/1 columns,\n",
        "# one for each category.\n",
        "#\n",
        "# drop_first=True removes one category (<1H OCEAN) because\n",
        "# if a district is not the other 4 categories,\n",
        "# it must be <1H OCEAN — so we don't need all 5 columns.\n",
        "\n",
        "# Only encode if the column still exists\n",
        "# This prevents errors when running the notebook more than once\n",
        "\n",
        "if 'ocean_proximity' in df.columns:\n",
        "    df = pd.get_dummies(df, columns=['ocean_proximity'], drop_first=True)\n",
        "    print(\"Encoding applied successfully!\")\n",
        "else:\n",
        "    print(\"Already encoded — skipping!\")\n",
        "\n",
        "ocean_cols = [col for col in df.columns if 'ocean' in col]\n",
        "print(\"\\n Count of 1s in each encoded column \")\n",
        "print(df[ocean_cols].sum())"
      ],
